  "structuralCSS": {
    ".ib-overlay": [
      "position: fixed",
      "inset: 0",
      "background: rgba(0,0,0,0.3)",
      "display: flex",
      "align-items: center",
      "justify-content: center",
      "z-index: 9999"
    ],
    ".ib-dialog": [
      "background: #ffffff",
      "border-radius: 8px",
      "box-shadow: 0 8px 32px rgba(0,0,0,0.2)",
      "overflow: hidden",
      "display: flex",
      "flex-direction: column"
    ],
    ".ib-header": [
      "display: flex",
      "align-items: center",
      "padding: 12px 16px",
      "background: #f5f5f5",
      "border-bottom: 1px solid #e5e5e5",
      "user-select: none",
      "cursor: default"
    ],
    ".ib-header-close": [
      "color: #999",
      "margin-left: auto",
      "width: 24px",
      "height: 24px",
      "display: flex",
      "align-items: center",
      "justify-content: center",
      "cursor: pointer",
      "border: none",
      "background: transparent",
      "font-size: 16px",
      "border-radius: 4px"
    ],
    ".ib-header-close:hover": [
      "background: #f0f0f0",
      "color: #333"
    ],
    ".ib-body": [
      "padding: 16px",
      "flex: 1"
    ],
    ".ib-prompt": [
      "font-size: 14px",
      "color: #555",
      "line-height: 1.6",
      "margin-bottom: 10px"
    ],
    ".ib-input": [
      "width: 100%",
      "padding: 8px 12px",
      "border: 1px solid #d9d9d9",
      "border-radius: 4px",
      "font-size: 14px",
      "color: #333",
      "outline: none",
      "box-sizing: border-box"
    ],
    ".ib-input:focus": [
      "border-color: #0078d4",
      "box-shadow: 0 0 0 2px rgba(0,120,212,0.2)"
    ],
    ".ib-footer": [
      "padding: 12px 16px",
      "display: flex",
      "justify-content: flex-end",
      "gap: 8px",
      "border-top: 1px solid #e5e5e5"
    ],
    ".ib-btn": [
      "padding: 6px 18px",
      "border: 1px solid #d9d9d9",
      "border-radius: 4px",
      "background: #ffffff",
      "color: #333",
      "font-size: 13px",
      "cursor: pointer",
      "min-width: 72px",
      "text-align: center"
    ],
    ".ib-btn:hover": [
      "background: #f0f0f0"
    ],
    ".ib-btn:active": [
      "background: #e0e0e0"
    ],
    ".ib-btn-primary": [
      "background: #0078d4",
      "color: #fff",
      "border-color: #0078d4"
    ],
    ".ib-btn-primary:hover": [
      "background: #106ebe"
    ],
    ".ib-btn-primary:active": [
      "background: #005a9e"
    ]
  },
