{
  "label": "卡片框",
  "icon": "⊞",
  "defaultStyleData": {
    "base": {
      "width": 260,
      "height": 180,
      "backgroundColor": "#ffffff",
      "borderColor": "#e0e0e0",
      "borderWidth": 1,
      "borderStyle": "solid",
      "borderRadius": 4,
      "headerColor": "#f5f5f5",
      "headerTitleColor": "#1E1F22",
      "collapseBtnColor": "#666666",
      "fontSize": 13,
      "color": "#333333",
      "display": "flex",
      "flexDirection": "column",
      "overflow": "hidden",
      "boxShadow": "0 1px 4px rgba(0, 0, 0, 0.08)",
      "fontFamily": "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif"
    },
    "pseudo": {},
    "sub": {
      ".card-header": {
        "height": "32px",
        "display": "flex",
        "align-items": "center",
        "justify-content": "space-between",
        "cursor": "pointer",
        "user-select": "none",
        "transition": "background-color 0.2s",
        "background-color": "#f5f5f5",
        "color": "#1E1F22",
        "padding": "0 12px"
      },
      ".card-header:hover": {
        "filter": "brightness(1)"
      },
      ".card-header-title": {
        "font-weight": "600",
        "font-size": "13px",
        "line-height": "32px"
      },
      ".card-collapse-btn": {
        "width": "24px",
        "height": "24px",
        "display": "flex",
        "align-items": "center",
        "justify-content": "center",
        "border": "none",
        "background": "none",
        "cursor": "pointer",
        "transition": "transform 0.2s cubic-bezier(0.4, 0, 0.2, 1)",
        "font-size": "12px",
        "line-height": "1",
        "padding": "0",
        "flex-shrink": "0",
        "color": "#666666",
        "margin-left": "auto"
      },
      ".card-collapse-btn.collapsed": {
        "transform": "rotate(-90deg)"
      },
      ".card-body": {
        "flex": "1",
        "position": "relative",
        "overflow": "hidden"
      },
      "#id.collapsed .card-body": {
        "display": "none"
      },
      ".card-collapse-btn:hover": {
        "color": "#333"
      },
      ".card-drop-hint": {
        "position": "absolute",
        "top": "50%",
        "left": "50%",
        "transform": "translate(-50%, -50%)",
        "color": "#ccc",
        "font-size": "12px",
        "pointer-events": "none",
        "white-space": "nowrap"
      }
    }
  },
  "defaultStyleLight": {
    "base": {
      "backgroundColor": "#ffffff",
      "borderColor": "#e0e0e0",
      "borderWidth": 1,
      "borderStyle": "solid",
      "borderRadius": 4,
      "headerColor": "#f5f5f5",
      "headerTitleColor": "#1E1F22",
      "collapseBtnColor": "#666666",
      "color": "#333333"
    },
    "pseudo": {},
    "sub": {}
  },
  "defaultStyleDark": {
    "base": {
      "backgroundColor": "#2d2d2d",
      "borderColor": "#555555",
      "borderWidth": 1,
      "borderStyle": "solid",
      "borderRadius": 4,
      "headerColor": "#3a3a3a",
      "headerTitleColor": "#e0e0e0",
      "collapseBtnColor": "#aaaaaa",
      "color": "#e0e0e0"
    },
    "pseudo": {},
    "sub": {}
  },
  "structuralCSS": {
    ".card-header": [
      "display: flex",
      "align-items: center",
      "justify-content: space-between",
      "cursor: pointer",
      "user-select: none",
      "transition: background-color 0.2s"
    ],
    ".card-header:hover": [
      "filter: brightness(0.95)"
    ],
    ".card-header-title": [
      "font-weight: 600",
      "font-size: 13px",
      "line-height: 1"
    ],
    ".card-collapse-btn": [
      "width: 24px",
      "height: 24px",
      "display: flex",
      "align-items: center",
      "justify-content: center",
      "border: none",
      "background: none",
      "cursor: pointer",
      "transition: transform 0.2s",
      "font-size: 12px",
      "line-height: 1",
      "padding: 0",
      "flex-shrink: 0",
      "margin-left: auto"
    ],
    ".card-collapse-btn.collapsed": [
      "transform: rotate(-90deg)"
    ],
    ".card-body": [
      "flex: 1",
      "position: relative",
      "overflow: hidden"
    ],
    "#id.collapsed .card-body": [
      "display: none"
    ],
    "#id.collapsed": [
      "height: 32px"
    ],
    ".card-collapse-btn:hover": [
      "color: #333"
    ],
    ".card-drop-hint": [
      "position: absolute",
      "top: 50%",
      "left: 50%",
      "transform: translate(-50%, -50%)",
      "color: #ccc",
      "font-size: 12px",
      "pointer-events: none",
      "white-space: nowrap"
    ]
  },
  "mappedProps": [
    {
      "selector": ".card-header",
      "base": {
        "backgroundColor": "#f5f5f5",
        "color": "#1E1F22"
      },
      "pseudo": {
        ":hover": {
          "filter": "brightness(0.95)"
        }
      }
    },
    {
      "selector": ".card-header-title",
      "base": {
        "fontSize": 13
      },
      "pseudo": {}
    },
    {
      "selector": ".card-collapse-btn",
      "base": {
        "color": "#666666"
      },
      "pseudo": {}
    }
  ],
  "computedProps": [
    {
      "selector": ".card-header",
      "jsonKey": "height",
      "cssProp": "height",
      "template": "{{headerHeight}}px"
    },
    {
      "selector": ".card-header",
      "jsonKey": "padding",
      "cssProp": "padding",
      "template": "{{headerPadding}}"
    },
    {
      "selector": ".card-header",
      "jsonKey": "background-color",
      "cssProp": "background-color",
      "template": "{{headerColor}}"
    },
    {
      "selector": ".card-header-title",
      "jsonKey": "color",
      "cssProp": "color",
      "template": "{{headerTitleColor}}"
    }
  ],
  "defaultProps": {
    "showHeader": true,
    "headerTitle": "卡片标题",
    "collapsible": true,
    "collapsed": false,
    "disabled": false,
    "visible": true
  }
}
